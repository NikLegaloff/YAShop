@model Sprut.StoreAdmin.Models.ProductViewModel
@using System.Web.UI.WebControls
@using Sprut.MyShop.Infrastructure
@using Sprut.StoreAdmin.Models

@{
    ViewBag.Title = "Index";
}

<br />
<div class="panel panel-default">
    <div class="panel-heading">
        <h3 class="panel-title">Products list</h3>
    </div>
    <div class="panel-body">
        <nav class="navbar navbar">
            <div class="btn-group" role="group" aria-label="...">
                <button type="button" class="btn btn-default">Add new product</button>
                <button type="button" class="btn btn-default">Import CSV</button>
                <button type="button" class="btn btn-default">Export CSV</button>
            </div>
        </nav>
            <div class="well">
                <form class="form-inline" id="filter">
                    @Html.HiddenFor(m => m.CurrentPage, new{id="CurrentPage"})
                    @Html.EditorFor(m => m.FilterTitle, new{ HtmlAttributes = new{@class="form-control",placeholder="Title"}})
                    @Html.DropDownListFor(m => m.FilterCategoryId, (SelectList) Model.CategorySelectList,"Choose category...", new { @class = "form-control"} )
                    @Html.EditorFor(m => m.FilterDescription, new{ HtmlAttributes = new{@class="form-control",placeholder="Description"}})

                    <button type="submit" class="btn btn-default">Filter</button>
                    <button type="reset" class="btn btn-default"><span class="glyphicon glyphicon-remove" aria-hidden="true"></span></button>
                </form>

        </div>
        <table class="table table-hover">
            <tr>
                <td>SKU</td>
                <td>Title</td>
                <td>Qty</td>
                <td>Price</td>
                <td>Image</td>
                <td>Descripton</td>
                <td>Category</td>
                <td></td>
            </tr>

            @foreach (var p in ViewBag.Products)
            {
                <tr>
                    <td>@p.SKU</td>
                    <td>@p.Title</td>
                    <td>@p.Qty</td>
                    <td>@p.Price</td>
                    <td>@p.Image</td>
                    <td>@p.Descripton</td>
                    <td>@Registry.Current.Categories.Find(p.CategoryId).Name</td>
                    <td>@Html.ActionLink("Edit", "Edit", new { sku = p.Id }) @Html.ActionLink("Delete", "DeleteProduct", new { sku = p.Id })</td>
                </tr>
            }
        </table>
        @*bad working in filter mod*@
        <nav aria-label="Page navigation" class="text-center">
            <ul class="pagination">
                <li>
                    <a href="#" onClick="goto(@(Model.CurrentPage-1))" aria-label="Previous">
                        <span aria-hidden="true">&laquo;</span>
                    </a>
                </li>
                @for (var i = 1; i < ViewBag.Count / 10; i++)
                {
                    if (i == Model.CurrentPage)
                    {
                        <li><a href="#" onclick="goto(@i)"><strong>@i</strong></a></li>
                    }
                    else
                    {
                        <li><a href="#" onclick="goto(@i)">@i</a></li>
                    }

                }
                <li>
                    <a href="#" onClick="goto(@(Model.CurrentPage+1))" aria-label="Next">
                        <span aria-hidden="true">&raquo;</span>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</div>


}
@section scripts
{
    <script>
        function goto(page) {
            if (page == 0) { page = 1 };
            if (page > @ViewBag.Count) { page =@ViewBag.Count};
            $("#CurrentPage").val(page);
            $("#filter").submit();
        };
    </script>
}








